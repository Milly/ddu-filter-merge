{
  "lock": false,
  "fmt": {
    "exclude": [
      "*.md"
    ]
  },
  "tasks": {
    "cache": "deno install",
    "check": "deno task check:lint && deno task check:fmt && deno task check:type && deno task check:doc",
    "check:lint": "deno lint",
    "check:fmt": "deno fmt --check",
    "check:type": "deno check --no-lock",
    "check:doc": "deno check --no-lock --doc-only **/*.ts **/*.md",
    "fix": "deno lint --fix && deno fmt",
    "test": "deno test -A --doc --parallel --shuffle"
  },
  "workspace": [
    "./denops/@ddu-filters/merge"
  ]
}
